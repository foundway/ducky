":"def joystick_Direction_callback(joystick_x_value, joystick_y_value):\n  global amplitude, command, center, center_tweak, amplitude_tweak \n  if joystick_y_value > 0:\n    amplitude = math.remap(math.sqrt(joystick_x_value ** 2 + joystick_y_value ** 2), 0, 100, 0, 40)\n    center = math.remap(joystick_x_value, (-100), 100, 60, 120)\n  else:\n    amplitude = 0\n    center = 90\n","event":"joystick_Direction_callback","type":"joystick","x":0,"y":0}],"modules":["remotePlus","remoteplus"],"cbIdList_":[],"eventCBIdList_":[],"apikey":"A05F8C63","uuid":"d9e0b916-eb25-410e-b4e5-4f11b158dfe1"}